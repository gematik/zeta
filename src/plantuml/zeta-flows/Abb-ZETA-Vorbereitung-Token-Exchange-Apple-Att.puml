@startuml "Abb-ZETA-Client-Statement-mit-Apple-AppAttest"
!include ../puml-layout.txt


' title Obtain Attestation Evidence

!pragma teoz true

participant SMB as "SM(C)-B" LEI_COMPONENT_COLOR
participant Konnektor as "Konnektor or\nTI-Gateway" LEI_COMPONENT_COLOR
box "Device" DEVICE_COLOR
  participant "Secure Enclave" as SE LEI_COMPONENT_COLOR
  participant OS as "OS (macOS)" LEI_COMPONENT_COLOR
  box "Primärsystem" PRIMAERSYSTEM_COLOR
    participant Client as "ZETA Client" <<zeta>>
  end box
end box

box "Anbieter TI 2.0 Dienst" PROVIDER_COLOR
  box "ZETA Guard" ZETA_GUARD_COLOR
    participant AuthS as "PDP\nAuthorization Server" <<zeta>>
  end box
end box


Client++
OS++
SE++
Client -> AuthS ++ : GET /nonce
AuthS --> Client -- : Nonce

Client -> Client : Create DPoP Key Pair\n(PrK.DPoP.Sig, PuK.DPoP.Sig)
Client -> Client: Erstelle Subject Token (mit Nonce)

group Sign Subject Token with SM(C)-B
    Client -> Konnektor ++: Sign Subject Token
    Konnektor -> SMB ++ : Sign Subject Token
    SMB --> Konnektor -- : Signed Subject Token
    Konnektor --> Client -- : Signed Subject Token
end

Client -> OS: Ermittle Posture\n(SIP, Gatekeeper, OS-Version, Secure Boot)
OS --> Client: Posture-Daten (Klartext)
Client -> Client: clientDataHash = Hash(Nonce + Posture-Daten)
Client -> OS: DCAppAttest.generateAssertion(\nkeyId: Handle_PrK.AK.Sig,  clientDataHash)
OS -> SE: Erstelle Hardware-Signatur\nüber clientDataHash
SE --> OS: Signatur + Authenticator Data (Counter)
OS --> Client: dc_assertion\n(CBOR: Signatur + authenticatorData)
Client -> Client: Generiere client-statement\n(Evidence = dc_assertion + Posture-Daten im Klartext)

@enduml