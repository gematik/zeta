@startuml "client-start"
autonumber "(00)"
skinparam defaultFontSize 10
skinparam defaultFontName Helvetica
skinparam DefaultMonospacedFontName Courier
skinparam lengthAdjust none
skinparam sequenceReferenceBackgroundColor White
skinparam SequenceReferenceFontSize 12
skinparam sequenceMessageAlign left

title Client Start & Initialisierung

!pragma teoz true

box "LEI" #GhostWhite
  participant "TPM / SE\n(Hardware)" as TPM
  box "Primärsystem" #Lavender
        box "ZAS Attester" #SandyBrown
        participant "ZAS\n(Attester)" as ZAS
    end box
    box "ZETA Client" #SandyBrown
        participant "PS und ZETA\nClient" as Client
    end box    
  end box
end box

alt Hardware Attestation (TPM / SE)
    ZAS -> ZAS: Startet als\n Hintergrunddienst\n (Root/Admin)
    
    alt Windows / Linux (TPM)
        ZAS --> ZAS: Messung des PS
        ZAS -> TPM: TPM2_PCR_Extend(23, Messwerte)
    else macOS (Secure Enclave)
        ZAS --> ZAS: Initiale Ermittlung\n der Posture (SIP-Status,\n Gatekeeper, OS-Version,\n Secure Boot Policy)
    end
    
    Client --> Client: Start \n (User Space)

else Software Attestation (Fallback)
    Client -> Client: Start \n (User Space)
    Client --> Client: Lokale \n Datensammlung \n (PS-Messung)
end

@enduml