@startuml "key-preparation"
skinparam sequenceMessageAlign center
title Key Preparation

participant "Apple\nServices" as Apple
participant "TPM / SE\n(Hardware)" as TPM
participant "ZAS\n(Attester)" as ZAS
participant "PS und ZETA\nClient" as Client

alt Hardware Attestation (TPM / SE)
    Client -> ZAS: dataToSign = Hash_PuK.Client.Sig
    alt Windows / Linux (TPM)
        ZAS -> TPM: TPM2_Sign(Handle_PrK.AK.Sig, dataToSign)
        TPM --> ZAS: signed_Hash_PuK.Client.Sig
        ZAS --> Client: PuK.AK.Sig, signed_Hash_PuK.Client.Sig
        Client -> ZAS: Request PuK.EK.Enc, C.EK.Enc
        ZAS -> TPM: TPM2_ReadPublic(EndorsementKey)
        TPM --> ZAS: PuK.EK.Enc
        ZAS -> TPM: TPM2_NV_Read(EndorsementKey)
        TPM --> ZAS: C.EK.Enc
        ZAS --> Client: PuK.EK.Enc, C.EK.Enc
    else macOS (Secure Enclave)
        ZAS -> TPM: SE_Sign(Handle_PrK.AK.Sig, dataToSign)
        TPM --> ZAS: signed_Hash_PuK.Client.Sig
        ZAS -> Apple: DCAppAttest.attest(Handle_PrK.AK.Sig, Hash_PuK.Client.Sig)
        Apple --> ZAS: Apple_Attestation_Object\n(inkl. x5c-Zertifikatskette)
        ZAS --> Client: PuK.AK.Sig, signed_Hash_PuK.Client.Sig,\nApple_Attestation_Object
    end
else Software Attestation (Fallback)
    note left of Client: Keine Hardware-Bindung.\nIdentität besteht nur aus PrK.Client.Sig, PuK.Client.Sig.
end

@enduml