@startuml "token-exchange-with-attestation"
skinparam sequenceMessageAlign center
title Token Exchange with Attestation

participant "PS und ZETA\nClient" as Client
participant "AuthS\n(Verifier)" as AuthS
participant "OPA\n(Endorser)" as OPA

Client++
Client -> AuthS++: GET /nonce
AuthS --> Client--: Nonce

alt Initial Token Exchange
    Client -> Client : Create DPoP Key Pair (PrK.DPoP.Sig, PuK.DPoP.Sig)
    note right: Session-based Key Pair for DPoP binding.

    Client -> Client : Create DPoP Proof (with Nonce from AuthS)
    Client -> AuthS++: POST /token\n{client_assertion (JWT, PrK.Client.Sig signiert),\nsubject_token (SMC-B signiert, inkl. Nonce),\n[Evidence]}

    group AuthS (Verifier & Policy Check)
        AuthS -> AuthS: Verifiziere client_assertion mit PuK.Client.Sig (aus DCR)
        AuthS -> AuthS: Verifiziere subject_token (SMC-B Zertifikat TI-PKI)
        AuthS -> AuthS: Extrahiere Nonce aus subject_token
        
        alt Hardware Attestation (TPM / SE)
            alt Windows / Linux (TPM)
                AuthS -> AuthS: Verifiziere Hardware-Signatur (Quote)\ngegen extrahierte Nonce
                AuthS -> AuthS: PCR-Replay via Event Log
                AuthS -> OPA++: Check PCR 7 & PCR 23 gegen Referenzwerte
            else macOS (Secure Enclave)
                AuthS -> AuthS: Prüfe counter > letzter counter (Replay-Schutz)
                AuthS -> OPA: Check macOS Posture gegen Referenzwerte
            end
            
        else Software Attestation (Fallback)
            AuthS -> AuthS: Extrahiere client-statement aus JWT
            AuthS -> OPA: Check Selbstauskunft (Software Policy)
        end
        
        OPA --> AuthS--: Attestation Result (Allow/Deny)
    end

    alt Token Exchange erfolgreich
        AuthS --> Client: 200 OK\n{Access Token, Refresh Token,\nZETA Guard Attestation Token}
    else Token Exchange fehlerhaft
        AuthS --> Client--: 403 Forbidden
    end

else Refresh Token use (without Attestation)
    Client -> Client : Create DPoP Proof (without Nonce)
    Client -> Client : Create Client Assertion JWT (without Attestation)
    Client -> AuthS++: POST /token\n{client_assertion (JWT, PrK.Client.Sig signiert),\nrefresh_token,\ndpop_proof (JWT, DPoP Key Pair signiert)}
    AuthS -> AuthS : Validate Request (Client Assertion,\nDPoP Proof, Refresh Token)
    AuthS -> AuthS: Invalidate Refresh token
    AuthS -> OPA++: Check Selbstauskunft (Software Policy)
    OPA --> AuthS--: Attestation Result (Allow/Deny)
    alt Token Exchange erfolgreich
        AuthS --> Client: 200 OK\n{Access Token, Refresh Token}
    else Token Exchange fehlerhaft
        AuthS --> Client--: 403 Forbidden
    end
end
@enduml