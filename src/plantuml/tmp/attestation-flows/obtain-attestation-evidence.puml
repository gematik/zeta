@startuml "obtain-attestation-evidence"
skinparam sequenceMessageAlign center
title Obtain Attestation Evidence

participant "TPM / SE\n(Hardware)" as TPM
participant "ZAS\n(Attester)" as ZAS
participant "PS und ZETA\nClient" as Client
participant Konnektor as "Konnektor or\nTI-Gateway"
participant SMB as "SM(C)-B"
participant "AuthS\n(Verifier)" as AuthS

Client++
Client -> AuthS ++ : GET /nonce
AuthS --> Client -- : Nonce

Client -> Client: Generiere subject_token
Client -> Konnektor ++ : externalAuthenticate (subject_token)
Konnektor -> SMB ++ : sign (subject_token)
SMB --> Konnektor -- : signature
Konnektor --> Client -- : signature
Client -> Client : Add signature to subject_token

alt Hardware Attestation (TPM / SE)
    Client -> ZAS++ : GetEvidence(Nonce)
    alt Windows / Linux (TPM)
        ZAS -> TPM++ : TPM2_Quote(PCR=[7,23], Nonce, Handle_PrK.AK.Sig)
        TPM --> ZAS -- : tpm_quote (signiert mit PrK.AK.Sig)
        ZAS -> TPM++ : TPM2_GetEventLog()
        TPM --> ZAS -- : tpm_event_log
        ZAS --> Client : Evidence {tpm_quote, tpm_event_log}
    else macOS (Secure Enclave)
        ZAS -> ZAS: Ermittle Posture\n(SIP, Gatekeeper, OS-Version, Secure Boot)
        ZAS -> TPM++ : DCAppAttest.generateAssertion(\n  Handle_PrK.AK.Sig,\n  Hash(Nonce + Posture)\n)
        TPM --> ZAS-- : dc_assertion\n(CBOR: Signatur + Receipt + counter)
        ZAS --> Client-- : Evidence {dc_assertion, posture, counter}
    end
else Software Attestation (Fallback)
    Client -> Client: Generiere client-statement\n(Selbstauskunft: OS, PS-Version)
end

@enduml