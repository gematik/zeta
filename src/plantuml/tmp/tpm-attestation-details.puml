@startuml "tpm-attestation-details"
skinparam sequenceMessageAlign center
title ZETA RATS Integration

participant "TPM\n(Hardware)" as TPM
participant "ZAS\n(Attester)" as ZAS
participant "PS und ZETA\nClient" as Client
participant "AuthS\n(Verifier)" as AuthS
participant "OPA\n(Endorser)" as OPA

== 1: Installation ==
ZAS --> ZAS: Installation
Client --> Client: Installation
ZAS --> ZAS: Messung des PS
ZAS --> ZAS: Vergleich der Messung mit\nWert des Herstellers
ZAS -> TPM: TPM2_CreatePrimary() → SRK
ZAS -> TPM: TPM2_Create(SRK, restricted=sign, fixedTPM=true)
TPM --> ZAS: AK_pub, AK_priv (blob)
ZAS -> TPM: TPM2_Load(SRK, AK_priv, AK_pub) → AK_Handle
ZAS -> TPM: PCR_Extend(23, Messwerte)

== 2: PS Start ==
Client --> Client: Start
ZAS --> ZAS: Messung des PS
ZAS -> TPM: PCR_Extend(23, Messwerte)

== 3: Bindungs-Vorbereitung ==
Client -> Client: Generiere CI_KeyPair (CI_pub/CI_prk)
Client -> ZAS: dataToSign = Hash(CI_pub)
ZAS -> TPM: TPM2_Sign(AK_Handle, dataToSign)
TPM --> ZAS: signature_CI
ZAS --> Client: AK_pub, signature_CI

== 4: Dynamic Client Registration (DCR) mit AK-EK Bindung ==
alt Kein ZETA Guard Attestation Token vorhanden
  Client -> ZAS: Request EK_pub, EK_Cert
  ZAS -> TPM: TPM2_ReadPublic(EK)
  TPM --> ZAS: EK_pub, EK_Cert
  ZAS --> Client: EK_pub, EK_Cert

  Client -> AuthS: POST /register\n{EK_pub, EK_Cert, AK_pub,\nCI_pub, signature_CI}

  AuthS -> AuthS: Validiere EK_Cert-Chain\n(Hersteller CA)
  AuthS -> AuthS: Prüfe signature_CI mit AK_pub\n→ CI_pub ist TPM-gebunden ✓
  AuthS -> AuthS: CredentialBlob =\nMakeCredential(EK_pub, Secret, AK_Name)

  AuthS --> Client: 202 Accepted {CredentialBlob}

  Client -> ZAS: Activate(CredentialBlob)
  ZAS -> TPM: TPM2_ActivateCredential(CredentialBlob)
  TPM --> ZAS: Secret
  ZAS --> Client: Secret

  Client -> AuthS: POST /register/verify {Secret}
  AuthS -> AuthS: Secret korrekt?\n→ AK ist TPM-gebunden ✓\nclient_id ↔ AK ↔ EK ↔ CI_pub

else ZETA Guard Attestation Token vorhanden
  Client -> AuthS: POST /register\n{ZETA Guard Attestation Token,\nCI_pub, signature_CI}
  AuthS -> AuthS: Prüfe Token & signature_CI\n→ CI_pub ist TPM-gebunden ✓
end

AuthS --> Client: 201 Created {client_id}

== 5: RATS Ablauf (Evidence & Token Exchange) ==
Client -> AuthS: GET /nonce
AuthS --> Client: Nonce

Client -> ZAS: GetEvidence(Nonce)
ZAS -> TPM: TPM2_Quote(PCR=[7,23], Nonce, AK_Handle)
TPM --> ZAS: tpm_quote (signiert mit AK)
ZAS -> TPM: TPM2_GetEventLog()
TPM --> ZAS: tpm_event_log
ZAS --> Client: Evidence\n{tpm_quote, tpm_event_log, posture}

Client -> AuthS: POST /token\n{client_assertion (JWT, CI_prk signiert),\nEvidence, Nonce}

group AuthS (Verifier & Policy Check)
    AuthS -> AuthS: Verifiziere client_assertion\nmit CI_pub (aus DCR)
    AuthS -> AuthS: Verifiziere Quote-Signatur\nmit AK_pub (aus DCR)
    AuthS -> AuthS: Verifiziere Nonce (Replay-Schutz)
    AuthS -> AuthS: PCR-Replay via Event Log
    AuthS -> OPA: Check PCR 7 (Secure Boot),\nPCR 23 (PS) gegen Referenzwerte
    OPA --> AuthS: Attestation Result (Allow/Deny)
end

alt Attestation erfolgreich
    AuthS --> Client: 200 OK\n{Access Token, Refresh Token,\nZETA Guard Attestation Token}
else Attestation fehlerhaft
    AuthS --> Client: 403 Forbidden
end
@enduml