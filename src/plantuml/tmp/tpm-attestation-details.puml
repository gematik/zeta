@startuml "tpm-attestation-details"
skinparam sequenceMessageAlign center
title ZETA RATS Integration (inkl. macOS SE, SW-Fallback & SMC-B)

participant "TPM / SE\n(Hardware)" as TPM
participant "ZAS\n(Attester)" as ZAS
participant "PS und ZETA\nClient" as Client
participant "AuthS\n(Verifier)" as AuthS
participant "OPA\n(Endorser)" as OPA

== 1: Installation ==
alt Hardware Attestation (TPM / SE)
    ZAS --> ZAS: Installation (als Root/Admin)
    Client --> Client: Installation (User Space)
    alt Windows / Linux (TPM)
        ZAS --> ZAS: Messung des PS & Vergleich
        ZAS -> TPM: TPM2_CreatePrimary() → SRK
        ZAS -> TPM: TPM2_Create(SRK, restricted=sign, fixedTPM=true)
        TPM --> ZAS: AK_pub, AK_priv (blob)
        ZAS -> TPM: TPM2_Load(SRK, AK_priv, AK_pub) → AK_Handle
        ZAS -> TPM: PCR_Extend(23, Messwerte)
    else macOS (Secure Enclave)
        ZAS -[#purple]> TPM: CryptoKit: Generate Key in SE
        TPM -[#purple]-> ZAS: SE_AK_pub
    end
else Software Attestation (Fallback)
    Client -[#green]> Client: Installation (ohne ZAS)
end

== 2: PS Start ==
alt Hardware Attestation (TPM / SE)
    Client --> Client: Start
    alt Windows / Linux (TPM)
        ZAS --> ZAS: Messung des PS
        ZAS -> TPM: PCR_Extend(23, Messwerte)
    else macOS (Secure Enclave)
        ZAS --> ZAS: Ermittle System Posture\n(SIP, SSV, FileVault)
    end
else Software Attestation (Fallback)
    Client -[#green]> Client: Start & lokale Datensammlung
end

== 3: Bindungs-Vorbereitung ==
Client -[#purple]> Client: Generiere CI_KeyPair (CI_pub/CI_prk)
alt Hardware Attestation (TPM / SE)
    Client -[#purple]> ZAS: dataToSign = Hash(CI_pub)
    alt Windows / Linux (TPM)
        ZAS -[#purple]> TPM: TPM2_Sign(AK_Handle, dataToSign)
        TPM -[#purple]-> ZAS: signature_CI
        ZAS -[#purple]-> Client: AK_pub, signature_CI
    else macOS (Secure Enclave)
        ZAS -[#purple]> TPM: SE_Sign(SE_AK, dataToSign)
        TPM -[#purple]-> ZAS: signature_CI
        ZAS -[#purple]-> Client: SE_AK_pub, signature_CI
    end
else Software Attestation (Fallback)
    note right of Client: Keine Hardware-Bindung.\nIdentität besteht nur aus CI_KeyPair.
end

== 4: Dynamic Client Registration (DCR) ==
alt Hardware Attestation: Windows / Linux (TPM)
    Client -[#purple]> ZAS: Request EK_pub, EK_Cert
    ZAS -[#purple]> TPM: TPM2_ReadPublic(EK)
    TPM -[#purple]-> ZAS: EK_pub, EK_Cert
    ZAS -[#purple]-> Client: EK_pub, EK_Cert

    Client -[#green]> AuthS: POST /register\n{EK_pub, EK_Cert, AK_pub, CI_pub, signature_CI}
    AuthS -[#purple]> AuthS: Validiere EK_Cert-Chain & signature_CI
    AuthS -[#purple]> AuthS: CredentialBlob = MakeCredential(...)
    AuthS -[#red]-> Client: 202 Accepted {CredentialBlob}

    Client -[#purple]> ZAS: Activate(CredentialBlob)
    ZAS -[#purple]> TPM: TPM2_ActivateCredential(CredentialBlob)
    TPM -[#purple]-> ZAS: Secret
    ZAS -[#purple]-> Client: Secret

    Client -[#red]> AuthS: POST /register/verify {Secret}
    AuthS -> AuthS: Secret korrekt? → CI_pub hardware-gebunden ✓
    AuthS -[#green]-> Client: 201 Created {client_id}

else Hardware Attestation: macOS (Secure Enclave)
    Client -[#purple]> ZAS: Request Attestation Object
    ZAS -[#purple]> TPM: Request Attestation (Apple Server)
    TPM -[#purple]-> ZAS: Apple_Attestation_Object
    ZAS -[#purple]-> Client: Apple_Attestation_Object
    
    Client -[#green]> AuthS: POST /register\n{SE_AK_pub, Apple_Attestation_Object, CI_pub, signature_CI}
    AuthS -[#purple]> AuthS: Validiere Apple Root CA & signature_CI
    AuthS -[#green]-> Client: 201 Created {client_id}

else Software Attestation (Fallback)
    Client -[#green]> AuthS: POST /register\n{CI_pub, attestation_type="software"}
    AuthS -[#green]> AuthS: Registriere Client-Instanz ohne HW-Bindung
    AuthS -[#green]-> Client: 201 Created {client_id}
end

== 5: RATS Ablauf (Evidence & Token Exchange) ==
Client -[#green]> AuthS: GET /nonce
AuthS -[#green]-> Client: Nonce

note over Client: Client lässt Subject Token von SMC-B\nsignieren (inkl. Nonce im Payload)
Client -> Client: Generiere subject_token (SMC-B signiert)

alt Hardware Attestation (TPM / SE)
    Client -> ZAS: GetEvidence(Nonce)
    alt Windows / Linux (TPM)
        ZAS -> TPM: TPM2_Quote(PCR=[7,23], Nonce, AK)
        TPM --> ZAS: tpm_quote (signiert mit AK)
        ZAS -> TPM: TPM2_GetEventLog()
        TPM --> ZAS: tpm_event_log
        ZAS --> Client: Evidence {tpm_quote, tpm_event_log}
    else macOS (Secure Enclave)
        ZAS -> ZAS: Ermittle aktuelle Posture (SIP, SSV, etc.)
        ZAS -> TPM: SE_Sign(SE_AK, Hash(Nonce + Posture))
        TPM --> ZAS: se_assertion
        ZAS --> Client: Evidence {se_assertion, posture}
    end
else Software Attestation (Fallback)
    Client -[#green]> Client: Generiere client-statement\n(Selbstauskunft: OS, PS-Version)
    note right of Client: client-statement wird direkt ins\nClient Assertion JWT eingebettet
end

Client -[#green]> AuthS: POST /token\n{client_assertion (JWT, CI_prk signiert),\nsubject_token (SMC-B signiert, inkl. Nonce),\n[Evidence]}

group AuthS (Verifier & Policy Check)
    AuthS -> AuthS: Verifiziere client_assertion mit CI_pub (aus DCR)
    AuthS -> AuthS: Verifiziere subject_token (SMC-B Zertifikat TI-PKI)
    AuthS -[#purple]> AuthS: Extrahiere Nonce aus subject_token
    
    alt Hardware Attestation (TPM / SE)
        AuthS -> AuthS: Verifiziere Hardware-Signatur (Quote/SE)\ngegen extrahierte Nonce (Replay-Schutz)
        
        alt Windows / Linux (TPM)
            AuthS -> AuthS: PCR-Replay via Event Log
            AuthS -> OPA: Check PCR 7 & PCR 23 gegen Referenzwerte
        else macOS (Secure Enclave)
            AuthS -> OPA: Check macOS Posture gegen Referenzwerte
        end
        
    else Software Attestation (Fallback)
        AuthS -[#green]> AuthS: Extrahiere client-statement aus JWT
        AuthS -[#green]> OPA: Check Selbstauskunft (Software Policy)
    end
    
    OPA --> AuthS: Attestation Result (Allow/Deny)
end

alt Attestation erfolgreich
    AuthS -[#green]-> Client: 200 OK\n{Access Token, Refresh Token,\n[ZETA Guard Attestation Token]}
else Attestation fehlerhaft
    AuthS -[#green]-> Client: 403 Forbidden
end
@enduml